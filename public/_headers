# Cloudflare static-asset headers.
# The love.js runtime (wasm + js) is content-stable and large, so cache it hard.
# The game data and HTML shell can change on a rebuild, so let those revalidate.
/games/*/love.wasm
  Cache-Control: public, max-age=31536000, immutable
/games/*/love.js
  Cache-Control: public, max-age=31536000, immutable
/games/*/game.js
  Cache-Control: public, max-age=604800
/games/*/game.data
  Cache-Control: public, max-age=604800
