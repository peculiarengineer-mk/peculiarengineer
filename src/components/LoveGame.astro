---
// LoveGame — embeds a LÖVE game compiled to WebAssembly with love.js.
// The heavy WASM runtime (~1.5 MB gzipped) is only fetched when the reader
// clicks Play: until then this is just a poster, so it costs the page nothing.
// The build lives under /public/games/<name>/ (index.html + love.js/wasm + data).
//
//   <LoveGame src="/games/platformer/" title="Platformer Demo"
//             controls="A/D move · Space jump · Down drop-through · R restart" />
interface Props {
	src: string; // folder holding the love.js build, e.g. "/games/platformer/"
	title: string;
	controls?: string; // one-line control hints shown under the frame
	ratio?: string; // CSS aspect-ratio of the game window (default 3:2, 960x640)
}
const { src, title, controls, ratio = '960 / 640' } = Astro.props;

// Resolve a bare folder to its index.html. Cloudflare Pages (and `astro preview`)
// serve the directory index for "/games/platformer/", but the dev server does not
// and 404s — so the embed would break only while writing the post. Naming the file
// works identically in both, and keeps the folder form valid at the call site.
const gameSrc = src.endsWith('/') ? `${src}index.html` : src;
---

<figure class="lovegame" data-src={gameSrc} style={`--ratio: ${ratio};`}>
	<div class="lovegame__frame">
		<button class="lovegame__play" type="button" aria-label={`Play ${title}`}>
			<span class="lovegame__icon" aria-hidden="true">▶</span>
			<span class="lovegame__title">{title}</span>
			<span class="lovegame__hint">Click to load &amp; play &middot; ~1.5 MB</span>
		</button>
	</div>
	{controls && <figcaption class="lovegame__caption">{controls}</figcaption>}
</figure>

<style>
	.lovegame {
		margin: 2em 0;
	}
	.lovegame__frame {
		position: relative;
		width: 100%;
		aspect-ratio: var(--ratio);
		background: #0d0d0d;
		border: 1px solid rgba(var(--sys-fg-rgb), 0.4);
		box-shadow: var(--box-shadow);
		overflow: hidden;
	}
	/* Poster button: fills the frame until clicked. */
	.lovegame__play {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.4em;
		width: 100%;
		height: 100%;
		cursor: pointer;
		border: 0;
		color: var(--sys-fg);
		font-family: var(--font-mono);
		background:
			radial-gradient(circle at center, rgba(var(--sys-fg-rgb), 0.08), transparent 70%),
			#0d0d0d;
		transition: background 0.15s ease;
	}
	.lovegame__play:hover,
	.lovegame__play:focus-visible {
		background:
			radial-gradient(circle at center, rgba(var(--sys-fg-rgb), 0.16), transparent 70%),
			#0d0d0d;
	}
	.lovegame__icon {
		font-size: 2.4em;
		line-height: 1;
		text-shadow: 0 0 12px rgba(var(--sys-fg-rgb), 0.6);
	}
	.lovegame__title {
		font-size: 1.1em;
		font-weight: 700;
	}
	.lovegame__hint {
		font-size: 0.8em;
		color: rgb(var(--gray));
	}
	/* The iframe injected on click fills the frame exactly. */
	.lovegame__frame :global(iframe) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}
	.lovegame__caption {
		margin-top: 0.6em;
		text-align: center;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
</style>

<script>
	// Swap the poster for the game iframe on first click. Delegated so every
	// <LoveGame> on a page shares one listener; each loads only when asked.
	document.addEventListener('click', (event) => {
		const btn = (event.target as HTMLElement).closest('.lovegame__play');
		if (!btn) return;
		const fig = btn.closest('.lovegame') as HTMLElement | null;
		const frame = btn.closest('.lovegame__frame');
		if (!fig || !frame) return;
		const src = fig.dataset.src;
		if (!src) return;

		const iframe = document.createElement('iframe');
		iframe.src = src;
		iframe.title = fig.querySelector('.lovegame__title')?.textContent ?? 'LÖVE game';
		iframe.allowFullscreen = true;
		iframe.setAttribute('loading', 'lazy');
		frame.replaceChildren(iframe);
		iframe.focus();
	});
</script>
