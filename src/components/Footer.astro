---
import SocialLinks from './SocialLinks.astro';

const today = new Date();
---

<footer>
	<div class="footer-id">
		<span class="brand">[SYS.ROOT] Peculiar Engineer</span>
		<span class="copy">&copy; {today.getFullYear()} Peculiar Engineer. Built for rigor.</span>
	</div>
	<SocialLinks />
</footer>
<style>
	footer {
		margin-top: 3em;
		padding: 1.5em 1em 3em 1em;
		background: var(--sys-bg);
		border-top: 1px solid var(--sys-fg);
		color: var(--sys-text);
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1.5em;
		max-width: 1100px;
		margin-left: auto;
		margin-right: auto;
	}
	.footer-id {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
		text-align: left;
	}
	.footer-id .brand {
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--sys-fg);
	}
	.footer-id .copy {
		color: var(--sys-dim);
		font-size: 0.85em;
	}
</style>
