---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import SocialLinks from './SocialLinks.astro';
---

<header>
	<nav>
		<div class="site-title">
			<a href="/"><span class="sys-tag">[SYS.ROOT]</span> {SITE_TITLE}</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">&gt; Home</HeaderLink>
			<HeaderLink href="/blog">&gt; Blog</HeaderLink>
			<HeaderLink href="/experiments">&gt; Experiments</HeaderLink>
			<HeaderLink href="/about">&gt; About</HeaderLink>
		</div>
		<SocialLinks />
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0.75em 1em;
		background: var(--sys-bg);
		border-bottom: 1px solid var(--sys-fg);
	}
	.site-title {
		margin: 0;
		font-size: 1.05em;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}
	.site-title a,
	.site-title a.active {
		text-decoration: none;
	}
	.site-title a:hover {
		background: transparent;
		color: var(--sys-fg);
	}
	.site-title .sys-tag {
		color: var(--sys-dim);
	}
	nav {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75em;
		max-width: 1100px;
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25em;
	}
	nav a {
		padding: 0.35em 0.6em;
		color: var(--sys-fg);
		text-transform: uppercase;
		font-size: 0.85em;
		text-decoration: none;
		border: 1px solid transparent;
	}
	nav a:hover {
		background: var(--sys-fg);
		color: var(--sys-bg);
	}
	nav a.active {
		border-color: var(--sys-dim);
	}
</style>
