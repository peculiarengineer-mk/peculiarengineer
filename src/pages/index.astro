---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🛠️ Peculiar Engineer</h1>
			<p>
				Hands-on tech guides, step-by-step install walkthroughs, and runbooks I've
				written down so I (and you) never have to figure them out twice.
			</p>
			<p>
				Everything here is practical and reproducible — copy-paste-able commands,
				gotchas I hit, and the fixes that actually worked.
			</p>
			<p>
				Head over to the <a href="/blog">blog</a> to browse the latest guides, or
				read a bit <a href="/about">about me</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
