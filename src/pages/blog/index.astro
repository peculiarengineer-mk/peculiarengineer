---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import CommandSearch from '../../components/CommandSearch.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.listing-head {
				color: var(--sys-dim);
				font-size: 0.85em;
				margin-bottom: 1.5em;
			}
			.listing-head .count {
				color: var(--sys-fg);
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1.5em;
			}
			li a {
				position: relative;
				display: block;
				border: 1px solid var(--sys-dim);
				padding: 1.25em 1.5em;
				text-decoration: none;
				color: var(--sys-fg);
			}
			li a:hover {
				border-color: var(--sys-fg);
				background: transparent;
			}
			li a:hover .title {
				text-decoration: underline;
				text-underline-offset: 4px;
			}
			.idx {
				color: var(--sys-dim);
				font-size: 0.8em;
			}
			.title {
				margin: 0.2em 0 0.4em;
				color: var(--sys-fg);
				line-height: 1.2;
				font-size: 1.3em;
			}
			.desc {
				margin: 0 0 0.6em;
				color: var(--sys-text);
				font-size: 0.9em;
			}
			.date {
				margin: 0;
				color: var(--sys-dim);
				font-size: 0.8em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<CommandSearch />
				<p class="listing-head">
					~/$ ls -la /blog &nbsp;&middot;&nbsp; <span class="count"
						>{posts.length}</span
					> entr{posts.length === 1 ? 'y' : 'ies'} found
				</p>
				<ul>
					{
						posts.map((post, i) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="idx">
										[{String(i + 1).padStart(2, '0')}] &gt;
									</span>
									<h4 class="title">{post.data.title}</h4>
									{post.data.description && <p class="desc">{post.data.description}</p>}
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
