---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import CommandSearch from '../../components/CommandSearch.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, sortByPubDate } from '../../consts';
import '../../styles/listing.css';

const posts = (await getCollection('blog')).sort(sortByPubDate);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`All posts — ${SITE_TITLE}`}
			description="Every post on Peculiar Engineer — tested fixes and how-tos for Linux, Ubuntu, SSH, Cloudflare, DevOps, and AI coding tools like Claude Code."
		/>
		<style>
			.listing li a {
				position: relative;
				display: block;
				border: 1px solid var(--sys-dim);
				padding: 1.25em 1.5em;
				text-decoration: none;
				color: var(--sys-fg);
			}
			.listing li a:hover {
				border-color: var(--sys-fg);
				background: transparent;
			}
			.listing li a:hover .title {
				text-decoration: underline;
				text-underline-offset: 4px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="listing">
				<CommandSearch />
				<h1 class="listing-head">
					~/$ ls -la /blog &nbsp;&middot;&nbsp; <span class="count"
						>{posts.length}</span
					> entr{posts.length === 1 ? 'y' : 'ies'} found
				</h1>
				<ul>
					{
						posts.map((post, i) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="idx">
										[{String(i + 1).padStart(2, '0')}] &gt;
									</span>
									<h2 class="title">{post.data.title}</h2>
									{post.data.description && <p class="desc">{post.data.description}</p>}
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
