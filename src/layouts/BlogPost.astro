---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = Omit<CollectionEntry<'blog'>['data'], 'pubDate'> & {
	pubDate?: Date;
	showDate?: boolean;
	kind?: 'article' | 'page';
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	showDate = true,
	kind = 'article',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const jsonLd =
	kind === 'page'
		? {
				'@context': 'https://schema.org',
				'@type': 'WebPage',
				name: title,
				description,
				...(heroImage && { image: new URL(heroImage.src, Astro.site).href }),
				url: canonicalURL.href,
				publisher: { '@type': 'Organization', name: 'Peculiar Engineer' },
			}
		: {
				'@context': 'https://schema.org',
				'@type': 'BlogPosting',
				headline: title,
				description,
				...(pubDate && { datePublished: pubDate.toISOString() }),
				...(updatedDate && { dateModified: updatedDate.toISOString() }),
				...(heroImage && { image: new URL(heroImage.src, Astro.site).href }),
				author: { '@type': 'Person', name: 'Minor Keith' },
				publisher: { '@type': 'Organization', name: 'Peculiar Engineer' },
				mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.href },
				url: canonicalURL.href,
				...(tags?.length && { keywords: tags.join(', ') }),
			};
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 0;
				border: 1px solid var(--sys-dim);
				filter: grayscale(0.3) brightness(0.9);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--sys-text);
			}
			.title {
				margin-bottom: 1em;
				padding: 1.5em 0 1em;
				text-align: left;
				line-height: 1.1;
			}
			.title h1 {
				margin: 0 0 0.3em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--sys-dim);
				font-family: var(--font-mono);
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				margin: 0.8em 0 0;
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--sys-dim);
				letter-spacing: 0.03em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						{
							showDate && pubDate && (
								<div class="date">
									<FormattedDate date={pubDate} />
									{updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)}
								</div>
							)
						}
						<h1>{title}</h1>
						{tags?.length && <div class="tags">{tags.map((tag) => `#${tag}`).join(' ')}</div>}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
